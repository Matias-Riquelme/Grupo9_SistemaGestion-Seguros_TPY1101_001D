# ==========================================
# VARIABLES DE ENTORNO - SISTEMA DE SEGUROS
# ==========================================
# IMPORTANTE: Este archivo contiene información sensible
# NO subir a repositorios públicos (agregar a .gitignore)

# ==========================================
# BASE DE DATOS - MySQL
# ==========================================
# Para ejecutar backends en local (sin Docker):
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/db_sistema_seguros?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=admin
# Para Docker usando MySQL LOCAL (docker-compose.local-mysql.yml):
# host.docker.internal apunta al MySQL de tu PC; usa estos valores:
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=admin
MYSQL_DATABASE=db_sistema_seguros
MYSQL_ROOT_PASSWORD=admin

# ==========================================
# KEYCLOAK - Autenticación
# ==========================================
KEYCLOAK_SERVER_URL=http://localhost:9090
KEYCLOAK_ISSUER_URI=http://localhost:9090/realms/spring-boot-realm-dev
KEYCLOAK_JWK_URI=http://localhost:9090/realms/spring-boot-realm-dev/protocol/openid-connect/certs
KEYCLOAK_REALM=spring-boot-realm-dev
KEYCLOAK_CLIENT_ID=spring-boot-client-dev
KEYCLOAK_CLIENT_SECRET=HrIdrnJjg91jEkLdFVMFS7Y6stLHk2qG
#Usuario Camilo
#KEYCLOAK_CLIENT_ID=spring-boot-api-rest

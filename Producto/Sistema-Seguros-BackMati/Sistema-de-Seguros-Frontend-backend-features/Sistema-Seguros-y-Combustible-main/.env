# ==========================================
# JWT - Tokens
# ==========================================
JWT_SECRET=mySecretKeyForJWTTokenValidationThatShouldBeAtLeast32Characters
JWT_EXPIRATION=3600000

# ==========================================
# ALMACENAMIENTO DE ARCHIVOS
# ==========================================
FILE_STORAGE_PATH=/data/storage

# ==========================================
# PUERTOS DE SERVICIOS
